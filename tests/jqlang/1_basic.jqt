[058-run]
LEVEL=run
JQ = {{{
[while(.<100; .*2)]
}}}
INPUT = {{{
1
}}}
EXPECTED = {{{
[1,2,4,8,16,32,64]
}}}
JFTL = {{{
{"main": "$pyrun=result = []\nv = _\nwhile v < 100:\n    result.append(v)\n    v = v * 2\nreturn result"}
}}}
COMMENT=No while/until construct; genuine imperative loop, hence run tier (this replaces an earlier, uglier self-applying-lambda version — real statements are the honest tool now that $pyrun supports them).

[059-skip]
JQ = {{{
[(label $here | .[] | if .>1 then break $here else . end), "hi!"]
}}}
INPUT = {{{
[0,1,2]
}}}
EXPECTED = {{{
[0,1,"hi!"]
}}}
SKIP=no label/break early-exit construct.

[060-skip]
JQ = {{{
[(label $here | .[] | if .>1 then break $here else . end), "hi!"]
}}}
INPUT = {{{
[0,2,1]
}}}
EXPECTED = {{{
[0,"hi!"]
}}}
SKIP=no label/break early-exit construct.

[061-eval]
LEVEL=eval
JQ = {{{
[.[]|[.,1]|until(.[0] < 1; [.[0] - 1, .[1] * .[0]])|.[1]]
}}}
INPUT = {{{
[1,2,3,4,5]
}}}
EXPECTED = {{{
[1,2,6,24,120]
}}}
JFTL = {{{
{"main": {"$": true, "foreach": {"in": "$."}, "body": "$pyeval=__import__('math').factorial(_)"}}
}}}
COMMENT=This specific until() loop happens to compute a factorial — doesn't generalize to arbitrary until() usage.

[062-skip]
JQ = {{{
[label $out | foreach .[] as $item ([3, null]; if .[0] < 1 then break $out else [.[0] -1, $item] end; .[1])]
}}}
INPUT = {{{
[11,22,33,44,55,66,77,88,99]
}}}
EXPECTED = {{{
[11,22,33]
}}}
SKIP=combines label/break (missing) and foreach state-threading (missing).

[063-logic]
LEVEL=logic
JQ = {{{
[foreach range(5) as $item (0; $item)]
}}}
INPUT = {{{
null
}}}
EXPECTED = {{{
[0,1,2,3,4]
}}}
JFTL = {{{
{"main": {"$": true, "foreach": {"shape": "range", "limit": 5}, "body": "$."}}
}}}
COMMENT=This foreach's update just re-emits the item, so it degrades to plain range iteration — coincidence, not a general foreach/reduce translation.

[064-eval]
LEVEL=eval
JQ = {{{
[foreach .[] as [$i, $j] (0; . + $i - $j)]
}}}
INPUT = {{{
[[2,1], [5,3], [6,4]]
}}}
EXPECTED = {{{
[1,3,5]
}}}
JFTL = {{{
{"main": "$pyeval=list(__import__('itertools').accumulate((p[0]-p[1] for p in _), initial=0))[1:]"}
}}}
COMMENT=itertools isn't whitelisted at py tier; JFTL has no accumulator threading across foreach iterations at all.

[065-eval]
LEVEL=eval
JQ = {{{
[foreach .[] as {a:$a} (0; . + $a; -.)]
}}}
INPUT = {{{
[{"a":1}, {"b":2}, {"a":3, "b":4}]
}}}
EXPECTED = {{{
[-1, -1, -4]
}}}
JFTL = {{{
{"main": "$pyeval=[-s for s in list(__import__('itertools').accumulate((d.get('a') or 0 for d in _), initial=0))[1:]]"}
}}}

[066-py]
LEVEL=py
JQ = {{{
[-foreach -.[] as $x (0; . + $x)]
}}}
INPUT = {{{
[1,2,3]
}}}
EXPECTED = {{{
