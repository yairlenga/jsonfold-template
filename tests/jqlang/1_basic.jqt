[048-eval]
LEVEL=eval
JQ = {{{
[(.,1),((.,.[]),(2,3))]
}}}
INPUT = {{{
["a","b"]
}}}
EXPECTED = {{{
[["a","b"],1,["a","b"],"a","b",2,3]
}}}
JFTL = {{{
{"main": {"$": true, "set": {"cur": "$."}, "body": "$pyeval=[cur, 1, cur, *cur, 2, 3]"}}
}}}
COMMENT=Star-unpacking (*cur) inside a list literal isn't in simpleeval's supported grammar, so eval tier.

