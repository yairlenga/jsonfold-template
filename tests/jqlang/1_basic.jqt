[017-py]
LEVEL=py
JQ = {{{
@html "<b>\(.)</b>"
}}}
INPUT = {{{
"<script>hax</script>"
}}}
EXPECTED = {{{
"<b>&lt;script&gt;hax&lt;/script&gt;</b>"
}}}
JFTL = {{{
{"main": "$py='<b>' + _.replace('&','&amp;').replace('<','&lt;').replace('>','&gt;').replace(\"'\",'&#39;').replace('\"','&quot;') + '</b>'"}
}}}
COMMENT=Chained .replace() calls only, no chr() — stays inside whitelisted string attrs.

[018-eval]
LEVEL=eval
JQ = {{{
[.[]|tojson|fromjson]
}}}
INPUT = {{{
["foo", 1, ["a", 1, "b", 2, {"foo":"bar"}]]
}}}
EXPECTED = {{{
["foo",1,["a",1,"b",2,{"foo":"bar"}]]
}}}
JFTL = {{{
{"main": {"$": true, "foreach": {"in": "$."}, "body": "$pyeval=__import__('json').loads(__import__('json').dumps(_))"}}
}}}

