[028-py]
LEVEL=py
JQ = {{{
.e0, .E1, .E-1, .E+1
}}}
INPUT = {{{
{"e0": 1, "E1": 2, "E": 3}
}}}
EXPECTED = {{{
1
2
2
4
}}}
JFTL = {{{
{"main": ["$.e0", "$.E1", "$py=(_['E'] if 'E' in _ else 0) - 1", "$py=(_['E'] if 'E' in _ else 0) + 1"]}
}}}
COMMENT=Used subscript+"in" instead of dict.get() (.get isn't whitelisted) to stay at py. Streaming gap: 4 outputs collected into one array.

[029-skip]
JQ = {{{
[.[]|.foo?]
}}}
INPUT = {{{
[1,[2],{"foo":3,"bar":4},{},{"foo":5}]
}}}
EXPECTED = {{{
[3,null,5]
}}}
SKIP=jq's "?" drops non-matching items from output entirely; foreach always emits one result per iteration.

[030-skip]
JQ = {{{
[.[]|.foo?.bar?]
}}}
INPUT = {{{
[1,[2],[],{"foo":3},{"foo":{"bar":4}},{}]
}}}
EXPECTED = {{{
[4,null]
}}}
SKIP=same output-suppression gap as 029.

[031-skip]
JQ = {{{
[..]
}}}
