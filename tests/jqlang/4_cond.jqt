[251-basic]
LEVEL=nav
JQ = {{{
[-if true then 1 else 2 end]
}}}
INPUT = {{{
null
}}}
EXPECTED = {{{
[-1]
}}}
JFTL = {{{
{"main": [-1]}
}}}
COMMENT=Condition is the literal true, fully determined — pure literal result.

[252-basic]
LEVEL=logic
JQ = {{{
{x: if true then 1 else 2 end}
}}}
INPUT = {{{
null
}}}
EXPECTED = {{{
{"x":1}
}}}
JFTL = {{{
{"main": {"x": {"$": true, "if": true, "body": 1, "default": 2}}}
}}}

[253-basic]
JQ = {{{
if true then [.] else . end []
}}}
INPUT = {{{
null
}}}
EXPECTED = {{{
null
}}}
SKIP=ambiguous parse (trailing "[]" suffix after the if-expression) not worth chasing for one deterministic-null result.

[254-basic]
LEVEL=py
JQ = {{{
[.[] | [.foo[] // .bar]]
}}}
INPUT = {{{
[{"foo":[1,2], "bar": 42}, {"foo":[1], "bar": null}, {"foo":[null,false,3], "bar": 18}, {"foo":[], "bar":42}, {"foo": [null,false,null], "bar": 41}]
}}}
EXPECTED = {{{
[[1,2], [1], [3], [42], [41]]
}}}
JFTL = {{{
{"main": "$py=[([v for v in d['foo'] if v not in (False, None)] or [d['bar']]) for d in _]"}
}}}
COMMENT=Python's "or" on a list is falsy-when-empty, which conveniently matches jq's // fallback-when-no-truthy-values semantics here.

[255-basic]
LEVEL=py
JQ = {{{
.[] //= .[0]
}}}
INPUT = {{{
["hello",true,false,[false],null]
}}}
EXPECTED = {{{
["hello",true,"hello",[false],"hello"]
}}}
JFTL = {{{
{"main": "$py=[v if v not in (False, None) else _[0] for v in _]"}
}}}

[256-basic]
LEVEL=py
JQ = {{{
.[] | [.[0] and .[1], .[0] or .[1]]
}}}
INPUT = {{{
[[true,[]], [false,1], [42,null], [null,false]]
}}}
EXPECTED = {{{
[true,true]
[false,true]
[false,true]
[false,false]
}}}
JFTL = {{{
{"main": {"$": true, "foreach": {"in": "$."}, "body": "$py=[(_[0] not in (False,None)) and (_[1] not in (False,None)), (_[0] not in (False,None)) or (_[1] not in (False,None))]"}}
}}}
COMMENT=jq's and/or return actual booleans (not the raw operand like Python's do), so each side is reduced to a boolean via jq's falsy rule before applying and/or.

[257-basic]
LEVEL=py
JQ = {{{
[.[] | not]
}}}
INPUT = {{{
[1,0,false,null,true,"hello"]
}}}
EXPECTED = {{{
[false,false,true,true,false,false]
}}}
JFTL = {{{
{"main": "$py=[v in (False, None) for v in _]"}
}}}
COMMENT=jq's falsy rule again — 0 is NOT falsy in jq, so "not 0" is false, matching the tuple-membership check rather than Python truthiness.

