# JFTL reference test corpus — chunk 4.
# Covers source lines ~1311-1502: Conditionals, contains, and try/catch.
# Continues the ID sequence (240+) from chunk 3.
#
# Good news this chunk: several tests that jq expresses with if/then/else
# map onto JFTL's *native* case/if/default logic instead of needing any
# expression engine at all — because JFTL's falsy rule (only false/null/
# MISSING are falsy, matching your memory notes) is exactly jq's falsy rule.
# So a per-item "if .foo then X else Y" becomes a plain foreach (no var) +
# case, tier logic, zero $py/$pyeval/$pyrun. Flagged per test where this
# applies.
#
# Also several "if ... end" tests turned out to be fully deterministic
# literals once you evaluate jq's own condition at compile time by hand
# (e.g. "if empty then 3 else 4 end" always produces zero outputs) — those
# landed at nav tier instead of the tier you'd expect from the jq source
# looking complicated.
#
# try/catch itself is still unimplemented, so most of that section is skip
# — except a handful where the catch branch is either unreachable or always
# fires deterministically, making the try/catch irrelevant to the actual
# output.
#
# Same caveats as chunks 1-3: not engine-verified, best-effort tier calls.

[240-basic]
LEVEL=logic
JQ = {{{
[.[] | if .foo then "yep" else "nope" end]
}}}
INPUT = {{{
[{"foo":0},{"foo":1},{"foo":[]},{"foo":true},{"foo":false},{"foo":null},{"foo":"foo"},{}]
}}}
EXPECTED = {{{
["yep","yep","yep","yep","nope","nope","yep","nope"]
}}}
JFTL = {{{
{"main": {"$": true, "foreach": {"in": "$."}, "body": {"$": true, "if": "$.foo", "body": "yep", "default": "nope"}}}
}}}
COMMENT=JFTL's falsy rule (only false/null/MISSING) matches jq's exactly, so "if $.foo" against the no-var foreach's current item reproduces this natively — no expression engine needed at all.

[241-basic]
LEVEL=logic
JQ = {{{
[.[] | if .baz then "strange" elif .foo then "yep" else "nope" end]
}}}
INPUT = {{{
[{"foo":0},{"foo":1},{"foo":[]},{"foo":true},{"foo":false},{"foo":null},{"foo":"foo"},{}]
}}}
EXPECTED = {{{
["yep","yep","yep","yep","nope","nope","yep","nope"]
}}}
JFTL = {{{
{"main": {"$": true, "foreach": {"in": "$."}, "body": {"$": true, "case": [{"when": "$.baz", "then": "strange"}, {"when": "$.foo", "then": "yep"}], "default": "nope"}}}
}}}
COMMENT=elif chain maps directly onto "case"'s ordered when/then list.

[242-basic]
LEVEL=nav
JQ = {{{
[if 1,null,2 then 3 else 4 end]
}}}
INPUT = {{{
null
}}}
EXPECTED = {{{
[3,4,3]
}}}
JFTL = {{{
{"main": [3, 4, 3]}
}}}
COMMENT=Condition is a fixed comma-generator (1,null,2), fully determined at read time — result is a pure literal.

[243-basic]
LEVEL=nav
JQ = {{{
[if empty then 3 else 4 end]
}}}
INPUT = {{{
null
}}}
EXPECTED = {{{
[]
}}}
JFTL = {{{
{"main": []}
}}}
COMMENT=empty as a condition produces zero if/then evaluations — always an empty result.

[244-basic]
LEVEL=nav
JQ = {{{
[if 1 then 3,4 else 5 end]
}}}
INPUT = {{{
null
}}}
EXPECTED = {{{
[3,4]
}}}
JFTL = {{{
{"main": [3, 4]}
}}}

[245-basic]
LEVEL=nav
JQ = {{{
[if null then 3 else 5,6 end]
}}}
INPUT = {{{
null
}}}
EXPECTED = {{{
[5,6]
}}}
JFTL = {{{
{"main": [5, 6]}
}}}

[246-basic]
LEVEL=nav
JQ = {{{
[if true then 3 end]
}}}
INPUT = {{{
7
}}}
EXPECTED = {{{
[3]
}}}
JFTL = {{{
{"main": [3]}
}}}

[247-basic]
LEVEL=nav
JQ = {{{
[if false then 3 end]
}}}
INPUT = {{{
7
}}}
EXPECTED = {{{
[7]
}}}
JFTL = {{{
{"main": ["$."]}
}}}
COMMENT=No else and condition false falls through to the current value — reproduced as navigation, generalizes to any input (not just 7).

