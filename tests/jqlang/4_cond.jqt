LEVEL=py
JQ = {{{
["hello" == "hello", "hello" != "hello", "hello" == "world", "hello" != "world" ]
}}}
INPUT = {{{
{}
}}}
EXPECTED = {{{
[true,false,false,true]
}}}
JFTL = {{{
{"main": "$py=['hello' == 'hello', 'hello' != 'hello', 'hello' == 'world', 'hello' != 'world']"}
}}}

