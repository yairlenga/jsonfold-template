JQ = {{{
[10 > 0, 10 > 10, 10 > 20, 10 < 0, 10 < 10, 10 < 20]
}}}
INPUT = {{{
{}
}}}
EXPECTED = {{{
[true,false,false,false,false,true]
}}}
JFTL = {{{
{"main": "$py=[10 > 0, 10 > 10, 10 > 20, 10 < 0, 10 < 10, 10 < 20]"}
}}}

