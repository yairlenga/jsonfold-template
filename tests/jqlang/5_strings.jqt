# JFTL reference test corpus — chunk 5.
# Covers source lines ~1503-1671: string operations, plus array/object
# contains() (a different overload from the string-substring contains()
# already covered in chunk 4). Continues the ID sequence (284+) from
# chunk 4.
#
# Nice find this chunk: index/rindex/indices don't actually need eval tier
# the way I originally did case 086 back in chunk 2 — str.find()/.rfind()
# aren't whitelisted, but min()/max()/range() ARE, so
#   min(i for i in range(len(_)) if _[i]==needle)
# gets you index(), max(...) gets you rindex(), and the bare comprehension
# gets you indices() — all within the py whitelist. Worth going back and
# retagging case 086 in chunk 2 from eval to py using this same trick if
# you want the corpus internally consistent; I haven't edited that file.
#
# Also: "ltrim" has no whitelisted equivalent directly — your STRING_ATTRS
# has "strip"/"rstrip" but no "lstrip". Worked around with
# v[::-1].rstrip()[::-1] (reverse, rstrip, reverse back) rather than
# bumping to eval tier for it.
#
# Same caveats as chunks 1-4: not engine-verified, best-effort tier calls.

[284-py]
LEVEL=py
JQ = {{{
[.[]|startswith("foo")]
}}}
INPUT = {{{
["fo", "foo", "barfoo", "foobar", "barfoob"]
}}}
EXPECTED = {{{
[false, true, false, true, false]
}}}
JFTL = {{{
{"main": "$py=[v.startswith('foo') for v in _]"}
}}}
COMMENT=Relies on startswith actually being reachable in your whitelist once the missing-comma bug (flagged back in chunk 1) is fixed.

[285-py]
LEVEL=py
JQ = {{{
[.[]|endswith("foo")]
}}}
INPUT = {{{
["fo", "foo", "barfoo", "foobar", "barfoob"]
}}}
EXPECTED = {{{
[false, true, true, false, false]
}}}
JFTL = {{{
{"main": "$py=[v.endswith('foo') for v in _]"}
}}}

[286-py]
LEVEL=py
JQ = {{{
[.[] | split(", ")]
}}}
INPUT = {{{
["a,b, c, d, e,f",", a,b, c, d, e,f, "]
}}}
EXPECTED = {{{
[["a,b","c","d","e,f"],["","a,b","c","d","e,f",""]]
}}}
JFTL = {{{
{"main": "$py=[v.split(', ') for v in _]"}
}}}

[287-py]
LEVEL=py
JQ = {{{
split("")
}}}
INPUT = {{{
"abc"
}}}
EXPECTED = {{{
["a","b","c"]
}}}
JFTL = {{{
{"main": "$py=[c for c in _]"}
}}}
COMMENT=Python's str.split('') raises ValueError (empty separator not allowed), so used a plain character comprehension instead of .split().

[288-py]
LEVEL=py
JQ = {{{
[.[]|ltrimstr("foo")]
}}}
INPUT = {{{
["fo", "foo", "barfoo", "foobar", "afoo"]
}}}
EXPECTED = {{{
["fo","","barfoo","bar","afoo"]
}}}
JFTL = {{{
{"main": "$py=[(v[3:] if v.startswith('foo') else v) for v in _]"}
}}}

[289-py]
LEVEL=py
JQ = {{{
[.[]|rtrimstr("foo")]
}}}
INPUT = {{{
["fo", "foo", "barfoo", "foobar", "foob"]
}}}
EXPECTED = {{{
["fo","","bar","foobar","foob"]
}}}
JFTL = {{{
{"main": "$py=[(v[:-3] if v.endswith('foo') else v) for v in _]"}
}}}

[290-py]
LEVEL=py
JQ = {{{
[.[]|trimstr("foo")]
}}}
INPUT = {{{
["fo", "foo", "barfoo", "foobarfoo", "foob"]
}}}
EXPECTED = {{{
["fo","","bar","bar","b"]
}}}
JFTL = {{{
{"main": "$py=[((v[3:] if v.startswith('foo') else v)[:-3] if (v[3:] if v.startswith('foo') else v).endswith('foo') else (v[3:] if v.startswith('foo') else v)) for v in _]"}
}}}
COMMENT=Chained ltrimstr-then-rtrimstr inline — readable is a stretch here, but stays in-grammar.

[291-nav]
LEVEL=nav
JQ = {{{
[.[]|ltrimstr("")]
}}}
INPUT = {{{
["a", "xx", ""]
}}}
EXPECTED = {{{
["a", "xx", ""]
}}}
JFTL = {{{
{"main": "$."}
}}}
COMMENT=Trimming an empty prefix is always a no-op — pure identity.

[292-nav]
LEVEL=nav
