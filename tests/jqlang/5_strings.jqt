}}}
INPUT = {{{
{}
}}}
EXPECTED = {{{
true
}}}
JFTL = {{{
{"main": true}
}}}

[323-nav]
LEVEL=nav
JQ = {{{
{foo: {baz: 12, blap: {bar: 13}}, bar: 14} | contains({bar: 14, foo: {blap: {bar: 14}}})
}}}
INPUT = {{{
{}
}}}
EXPECTED = {{{
false
}}}
JFTL = {{{
{"main": false}
}}}
