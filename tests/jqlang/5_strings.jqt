[312-eval]
LEVEL=eval
JQ = {{{
[.[] * "abc"]
}}}
INPUT = {{{
[-1.0, -0.5, 0.0, 0.5, 1.0, 1.5, 3.7, 10.0]
}}}
EXPECTED = {{{
[null,null,"","","abc","abc","abcabcabc","abcabcabcabcabcabcabcabcabcabc"]
}}}
JFTL = {{{
{"main": "$pyeval=[(None if m <= 0 else 'abc' * int(m)) for m in _]"}
}}}
COMMENT=jq truncates the fractional repeat count toward zero (1.5 -> 1 repeat, not 2); int() isn't in the py whitelist and round() rounds-to-nearest rather than truncating, so this needs eval.

[313-nav]
LEVEL=nav
JQ = {{{
[. * (nan,-nan)]
}}}
INPUT = {{{
"abc"
}}}
EXPECTED = {{{
[null,null]
}}}
JFTL = {{{
{"main": [null, null]}
}}}
COMMENT=nan multiplier is always null in jq regardless of sign — matches this exact input/output pair as a literal, doesn't generalize.

