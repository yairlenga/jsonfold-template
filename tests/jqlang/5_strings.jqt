[.[]|rtrimstr("")]
}}}
INPUT = {{{
["a", "xx", ""]
}}}
EXPECTED = {{{
["a", "xx", ""]
}}}
JFTL = {{{
{"main": "$."}
}}}

[293-nav]
LEVEL=nav
JQ = {{{
[.[]|trimstr("")]
}}}
INPUT = {{{
