[298-py]
LEVEL=py
COMMENT = {{{
trim
 is vertical tab (\v not supported by json)
}}}
JQ = {{{
map(trim), map(ltrim), map(rtrim)
}}}
INPUT = {{{
[" \n\t\r\f", "","  ", "a", " a ", "abc", "  abc  ", "  abc", "abc  "]
}}}
EXPECTED = {{{
["", "", "", "a", "a", "abc", "abc", "abc", "abc"]
["", "", "", "a", "a ", "abc", "abc  ", "abc", "abc  "]
["", "", "", "a", " a", "abc", "  abc", "  abc", "abc"]
}}}
JFTL = {{{
{"main": ["$py=[v.strip() for v in _]", "$py=[v[::-1].rstrip()[::-1] for v in _]", "$py=[v.rstrip() for v in _]"]}
}}}
COMMENT=No lstrip in the whitelist — ltrim done via reverse/rstrip/reverse-back instead. Streaming gap: 3 outputs collected into one array.

[299-py]
LEVEL=py
JQ = {{{
trim, ltrim, rtrim
}}}
INPUT = {{{
"\u0009\u000A\u000B\u000C\u000D\u0020\u0085\u00A0\u1680\u2000\u2001\u2002\u2003\u2004\u2005\u2006\u2007\u2008\u2009\u200A\u2028\u2029\u202F\u205F\u3000abc\u0009\u000A\u000B\u000C\u000D\u0020\u0085\u00A0\u1680\u2000\u2001\u2002\u2003\u2004\u2005\u2006\u2007\u2008\u2009\u200A\u2028\u2029\u202F\u205F\u3000"
}}}
EXPECTED = {{{
"abc"
"abc\u0009\u000A\u000B\u000C\u000D\u0020\u0085\u00A0\u1680\u2000\u2001\u2002\u2003\u2004\u2005\u2006\u2007\u2008\u2009\u200A\u2028\u2029\u202F\u205F\u3000"
"\u0009\u000A\u000B\u000C\u000D\u0020\u0085\u00A0\u1680\u2000\u2001\u2002\u2003\u2004\u2005\u2006\u2007\u2008\u2009\u200A\u2028\u2029\u202F\u205F\u3000abc"
}}}
JFTL = {{{
{"main": ["$py=_.strip()", "$py=_[::-1].rstrip()[::-1]", "$py=_.rstrip()"]}
}}}
COMMENT=Assumes Python's str.strip() treats this exact set of Unicode whitespace codepoints the same as jq's trim — worth spot-checking, not independently verified codepoint-by-codepoint.

