[454-run]
LEVEL=run
JQ = {{{
reduce .[] as $then (4 as $else | $else; . as $elif | . + $then * $elif)
}}}
INPUT = {{{
[1,2,3]
}}}
EXPECTED = {{{
96
}}}
JFTL = {{{
{"main": "$pyrun=acc = 4\nfor x in _:\n    acc = acc + x * acc\nreturn acc"}
}}}
COMMENT=$then/$else/$elif here are just keyword-shadowed variable names, not real if/then/else — stripping that away, this is a plain fold: acc *= (1 + x) for each x, starting from 4.

[455-nav]
LEVEL=nav
JQ = {{{
1 as $foreach | 2 as $and | 3 as $or | { $foreach, $and, $or, a }
}}}
INPUT = {{{
{"a":4,"b":5}
}}}
EXPECTED = {{{
{"foreach":1,"and":2,"or":3,"a":4}
}}}
JFTL = {{{
{"main": {"foreach": 1, "and": 2, "or": 3, "a": "$.a"}}
}}}
COMMENT=$foreach/$and/$or are keyword-shadowed variable names bound to constants; the object construction itself is a plain literal skeleton plus one field nav for "a".

[456-run]
LEVEL=run
JQ = {{{
[ foreach .[] as $try (1 as $catch | $catch - 1; . + $try; .) ]
}}}
INPUT = {{{
[10,9,8,7]
}}}
EXPECTED = {{{
[10,19,27,34]
}}}
JFTL = {{{
{"main": "$pyrun=state = 0\nout = []\nfor x in _:\n    state = state + x\n    out.append(state)\nreturn out"}
}}}
COMMENT=$try/$catch are keyword-shadowed names, not real try/catch. This is jq's foreach init;update;extract running total; JFTL's foreach construct doesn't carry a fold accumulator across iterations, so a real loop at run tier collects the running totals directly. Streaming gap: jq's 4 outputs collected into one array.

