[476-eval]
LEVEL=eval
COMMENT=explode/implode. Test replacement character (65533) for outside codepoint range and 0xd800 (55296) - 0xdfff (57343) utf16 surrogate pair range. 1.1 and 1.9 to test round down of non-ints.
JQ = {{{
implode|explode
}}}
INPUT = {{{
[-1,0,1,2,3,1114111,1114112,55295,55296,57343,57344,1.1,1.9]
}}}
EXPECTED = {{{
[65533,0,1,2,3,1114111,65533,55295,65533,65533,57344,1,1]
}}}
JFTL = {{{
{"main": "$pyeval=[65533 if (int(x) < 0 or int(x) > 1114111 or 55296 <= int(x) <= 57343) else int(x) for x in _]"}
}}}
COMMENT=Implemented the clamping rule directly (replacement char for out-of-range or surrogate-range codepoints, floor for fractional ones) rather than round-tripping through an actual Python string, which would choke on lone surrogates.

