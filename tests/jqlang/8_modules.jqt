[423-nav]
LEVEL=nav
COMMENT=Regression test for #1347
JQ = {{{
(.a as $x | .b) = "b"
}}}
INPUT = {{{
{"a":null,"b":null}
}}}
EXPECTED = {{{
{"a":null,"b":"b"}
}}}
JFTL = {{{
{"main": {"a": "$.a", "b": "b"}}
}}}
COMMENT=The "$x" binding along the path doesn't change what gets assigned — the actual target is just .b — so this reduces to a plain literal skeleton with .a passed through and .b overwritten.

