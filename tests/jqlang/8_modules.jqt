[411-eval]
LEVEL=eval
COMMENT=Basic numbers tests: integers, powers of two
JQ = {{{
[range(-52;52;1)] as $powers | [$powers[]|pow(2;.)|log2|round] == $powers
}}}
INPUT = {{{
null
}}}
EXPECTED = {{{
true
}}}
JFTL = {{{
{"main": "$pyeval=[round(__import__('math').log2(2**p)) for p in range(-52,52)] == list(range(-52,52))"}
}}}
COMMENT=Round-trips pow(2;p)|log2 for p in -52..51 and checks it recovers p exactly. Relies on Python's float precision matching jq's here — not verified against a real jq run.

