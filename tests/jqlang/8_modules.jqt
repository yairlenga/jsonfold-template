}}}
EXPECTED = {{{
"a,"
",a"
}}}
JFTL = {{{
{"main": {"$": true, "foreach": {"in": "$."}, "body": "$py=','.join('' if v == None else v for v in _)"}}
}}}
TRANSFORM=stream
COMMENT=Same pattern as 401. Streaming  2 outputs collected into one array.

