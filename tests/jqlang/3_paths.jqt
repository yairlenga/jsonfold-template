# JFTL reference test corpus — chunk 3.
# Covers source lines ~1106-1310: Paths (path()/getpath/setpath/delpaths/
# pick) and Assignment. Continues the ID sequence (197+) from chunk 2.
#
# Heads up: path()/getpath/setpath/delpaths are jq's path-as-data feature
# set. JFTL has nothing resembling "paths as first-class values" (no path(),
# no generic getpath/setpath/delpaths) — most of this section is SKIP.
# Where a test uses a fixed, compile-time-known literal path, I hand-built a
# one-off equivalent (dict-spread rebuild, index math) rather than a general
# path primitive — flagged per test, not a real setpath/getpath replacement.
#
# Same caveats as chunks 1-2: not engine-verified, best-effort tier calls.

[197-skip]
JQ = {{{
path(.foo[0,1])
}}}
INPUT = {{{
null
}}}
EXPECTED = {{{
["foo", 0]
["foo", 1]
}}}
SKIP=path() introspection (paths as data) has no JFTL equivalent.

[198-skip]
JQ = {{{
path(.[] | select(.>3))
}}}
INPUT = {{{
[1,5,3]
}}}
EXPECTED = {{{
[1]
}}}
SKIP=same as 197.

[199-skip]
JQ = {{{
path(.)
}}}
INPUT = {{{
42
}}}
EXPECTED = {{{
[]
}}}
SKIP=same as 197.

[200-skip]
JQ = {{{
try path(.a | map(select(.b == 0))) catch .
}}}
INPUT = {{{
{"a":[{"b":0}]}
}}}
EXPECTED = {{{
"Invalid path expression with result [{\"b\":0}]"
}}}
SKIP=needs path() and try/catch, neither implemented.

