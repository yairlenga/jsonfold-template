[216-py]
LEVEL=py
COMMENT=negative index
JQ = {{{
setpath([-1]; 1)
}}}
INPUT = {{{
[0]
}}}
EXPECTED = {{{
[1]
}}}
JFTL = {{{
{"main": "$py=_[:-1] + [1]"}
}}}

[217-nav]
LEVEL=nav
JQ = {{{
pick(.a.b.c)
}}}
INPUT = {{{
null
}}}
EXPECTED = {{{
{"a":{"b":{"c":null}}}
}}}
JFTL = {{{
{"main": {"a": {"b": {"c": null}}}}
}}}
COMMENT=Input is null, so the picked leaf is always null regardless — the whole result is a fixed literal skeleton for this input, hence nav tier.

[218-py]
LEVEL=py
JQ = {{{
pick(first)
}}}
INPUT = {{{
[1,2]
}}}
EXPECTED = {{{
[1]
}}}
JFTL = {{{
{"main": "$py=_[:1]"}
}}}
COMMENT=pick(first) preserves array shape with only the first element — slicing reproduces that for this input.

[219-py]
LEVEL=py
JQ = {{{
pick(first|first)
}}}
INPUT = {{{
[[10,20],30]
}}}
EXPECTED = {{{
[[10]]
}}}
JFTL = {{{
{"main": "$py=[_[0][:1]]"}
}}}

[220-skip]
COMMENT=negative indices in path expressions (since last/1 is .[-1])
JQ = {{{
try pick(last) catch .
}}}
INPUT = {{{
[1,2]
}}}
EXPECTED = {{{
"Out of bounds negative array index"
}}}
SKIP=needs try/catch.

[221-py]
LEVEL=py
JQ = {{{
.message = "goodbye"
}}}
INPUT = {{{
{"message": "hello"}
}}}
EXPECTED = {{{
{"message": "goodbye"}
}}}
JFTL = {{{
{"main": "$py={**_, 'message': 'goodbye'}"}
}}}
COMMENT=No in-place path assignment; dict-spread rebuild preserves any other keys, unlike a bare literal replacement would.

[222-py]
LEVEL=py
JQ = {{{
.foo = .bar
}}}
INPUT = {{{
{"bar":42}
}}}
EXPECTED = {{{
{"foo":42, "bar":42}
}}}
JFTL = {{{
{"main": "$py={**_, 'foo': _['bar'] if 'bar' in _ else None}"}
}}}

[223-py]
