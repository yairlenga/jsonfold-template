{
  "$": true,
  "set": {
    "subtotal": "$.order.subtotal",
    "taxRate": "$.order.taxRate"
  },
  "body": {
    "customerName": "$.customer.name",
    "total": "$pyrun: round(subtotal * (1 + taxRate), 2)",
    "itemCount": "$pyrun: len(_input['items'])",
    "itemSummary": "$pyrun: ', '.join([i['name'] for i in _input['items']])"
  }
}
