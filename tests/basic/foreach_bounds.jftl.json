{
    "main": {
        "$": true,
        "set": {
            "letters": ["aa", "bb", "cc", "dd", "ee", "ff", "gg", "hh", "ii"],
            "starts": [null, 2, -3],
            "stops": [null, 6, -2],
            "limits": [null, 0, 4]
        },
        "foreach": {
            "in": "$starts",
            "value": "s"
        },
        "body": {
            "$": true,
            "foreach": {
                "in": "$stops",
                "value": "e"
            },
            "body": {
                "$": true,
                "foreach": {
                    "in": "$limits",
                    "value": "l"
                },
                "body": {
                    "start": "$s",
                    "stop": "$e",
                    "limit": "$l",
                    "subset": {
                        "$": true,
                        "foreach": {
                            "in": "$letters",
                            "start": "$s",
                            "stop": "$e",
                            "limit": "$l"
                        },
                        "body": "$"
                    }
                }
            }
        }
    }
}
