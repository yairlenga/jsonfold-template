{
  "main": {
    "$": true,
    "set": {
      "subtotal": "$.order.subtotal",
      "taxRate": "$.order.taxRate"
    },
    "body": {
      "customerName": "$.customer.name",
      "total": "$py= round(subtotal * (1 + taxRate), 2)",
      "itemCount": "$py= len(_input['items'])",
      "itemSummary": "$py= ', '.join([i['name'] for i in _input['items']])"
    }
  }
}
