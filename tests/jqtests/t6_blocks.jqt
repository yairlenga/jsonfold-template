[333-blocks]
LEVEL=py
JQ = {{{
to_entries
}}}
INPUT = {{{
{"a": 1, "b": 2}
}}}
GOLD = {{{
[{"key":"a", "value":1}, {"key":"b", "value":2}]
}}}
JFTL = {{{
{"main": {"$": true, "foreach": {"key": "k", "var": "v", "in": "$."}, "body": {"key": "$py=k", "value": "$py=v"}}}
}}}
COMMENT=Native foreach key+var, avoiding dict.items() (not whitelisted) entirely.

[334-blocks]
LEVEL=py
JQ = {{{
from_entries
}}}
INPUT = {{{
[{"key":"a", "value":1}, {"Key":"b", "Value":2}, {"name":"c", "value":3}, {"Name":"d", "Value":4}]
}}}
GOLD = {{{
{"a": 1, "b": 2, "c": 3, "d": 4}
}}}
JFTL = {{{
{"main": "$py={(d['key'] if 'key' in d else (d['Key'] if 'Key' in d else (d['name'] if 'name' in d else d['Name']))): (d['value'] if 'value' in d else d['Value']) for d in _}"}
}}}
COMMENT=jq's from_entries accepts several key/value field-name aliases; checked each via "in" rather than dict.get() (not whitelisted). Only covers the 4 aliases exercised by this test, not jq's full alias list (also k/K/v/V).

[335-blocks]
LEVEL=py
JQ = {{{
with_entries(.key |= "KEY_" + .)
}}}
INPUT = {{{
{"a": 1, "b": 2}
}}}
GOLD = {{{
{"KEY_a": 1, "KEY_b": 2}
}}}
JFTL = {{{
{"main": "$py={('KEY_' + k): _[k] for k in _}"}
}}}
COMMENT=with_entries here needs to rename keys, which JFTL's foreach OUT_MODE:"OBJECT" can't do (it always keys the result by the loop's own key, not whatever the body computes) — did it as a plain dict comprehension over "for k in _" (dict iteration yields keys) instead of going through foreach at all.

