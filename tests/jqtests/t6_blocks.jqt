}}}
JFTL = {{{
{"main": "$py=[[row[i] if i < len(row) else None for row in _] for i in range(max(len(row) for row in _))]"}
}}}
COMMENT=Built from max/range/len (all whitelisted) rather than itertools.zip_longest — stays at py tier.

