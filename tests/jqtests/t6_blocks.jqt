}}}
GOLD = {{{
[0, 1, 2, 1, [3], 2]
}}}
JFTL = {{{
{"main": "$pyrun=result = list(_)\nfor _pass in range(2):\n    new_result = []\n    for item in result:\n        if isinstance(item, list):\n            new_result.extend(item)\n        else:\n            new_result.append(item)\n    result = new_result\nreturn result"}
}}}

[356-blocks]
JQ = {{{
try flatten(-1) catch .
}}}
INPUT = {{{
[0, [1], [[2]], [[[3]]]]
}}}
