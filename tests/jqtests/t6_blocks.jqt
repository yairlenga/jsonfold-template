[360-blocks]
LEVEL=py
JQ = {{{
ascii_upcase
}}}
INPUT = {{{
"useful but not for é"
}}}
GOLD = {{{
"USEFUL BUT NOT FOR é"
}}}
JFTL = {{{
{"main": "$py=''.join(ch.upper() if 'a' <= ch <= 'z' else ch for ch in _)"}
}}}
COMMENT=Restricted .upper() to a-z only, matching jq's ASCII-only upcase rather than Python's locale-aware str.upper() (which would also upcase 'é').
